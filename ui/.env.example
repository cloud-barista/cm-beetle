# Backend service endpoints used by Next.js API route handlers (server-side only).
# In local development these default to localhost ports.
# In Docker Compose these are overridden with internal DNS names (e.g. http://cm-honeybee:8081).
BEETLE_ENDPOINT=http://localhost:8056
TUMBLEBUG_ENDPOINT=http://localhost:1323
HONEYBEE_ENDPOINT=http://localhost:8081
DAMSELFLY_ENDPOINT=http://localhost:8082
